# Keep the build context small and the image reproducible. NOTE: .git is NOT
# ignored — build.rs reads it to stamp the commit SHA into `icegres --version`.
# It is copied explicitly and only into the builder stage, never the runtime.

# Rust build output (rebuilt inside the image; copying it in would poison the
# cache and bloat the context by gigabytes).
**/target/

# Local test / bench runtime state.
icegres/.e2e/
bench/.run/
bench/results/
bench/clients/jars/
**/*.log
**/*.pid
__pycache__/
**/*.pyc

# Editor / OS noise.
.DS_Store
